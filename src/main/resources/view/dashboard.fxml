<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="700" prefWidth="1100" stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.nighthawkdb.controller.MainController">

    <!-- Barra Lateral Esquerda -->
    <left>
        <VBox fx:id="sidebarVBox" prefWidth="220" styleClass="sidebar" spacing="8">
            <padding>
                <Insets top="20" right="10" bottom="20" left="10"/>
            </padding>

            <Label text="NighthawksDB" styleClass="sidebar-server-name" />
            <Separator styleClass="sidebar-separator" />

            <Button text="🔥 Firebird/Manutenção" styleClass="nav-button, nav-button-active" maxWidth="Infinity" />
            <Button text="⚖ Comparador Firebird" styleClass="nav-button" maxWidth="Infinity" onAction="#navegarParaCompiler" />
            <Button text="🔷 MSSQL Tools" styleClass="nav-button" maxWidth="Infinity" onAction="#abrirMSSQLPlaceholder" />

            <Region VBox.vgrow="ALWAYS" />
            <Button text="ℹ Sobre" styleClass="nav-button" maxWidth="Infinity" onAction="#abrirJanelaSobre" />
        </VBox>
    </left>

    <!-- Conteúdo Central -->
    <center>
        <VBox spacing="15" styleClass="main-content">
            <padding>
                <Insets top="20" right="30" bottom="20" left="30"/>
            </padding>

            <!-- Cabeçalho -->
            <HBox alignment="CENTER_LEFT">
                <Label text="Manutenção Firebird" styleClass="main-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="● SISTEMA ONLINE" styleClass="uptime-badge" />
            </HBox>

            <!-- Painel de Portas -->
            <HBox spacing="15" styleClass="ports-panel" alignment="CENTER_LEFT">
                <Label text="Portas" styleClass="ports-label" />
                <HBox spacing="10">
                    <HBox spacing="4" alignment="CENTER">
                        <Circle fx:id="circle3050" radius="5" fill="RED" />
                        <Label text="3050" styleClass="port-text" />
                    </HBox>
                    <HBox spacing="4" alignment="CENTER">
                        <Circle fx:id="circle3051" radius="5" fill="RED" />
                        <Label text="3051" styleClass="port-text" />
                    </HBox>
                    <HBox spacing="4" alignment="CENTER">
                        <Circle fx:id="circle3052" radius="5" fill="RED" />
                        <Label text="3052" styleClass="port-text" />
                    </HBox>
                    <HBox spacing="4" alignment="CENTER">
                        <Circle fx:id="circle53052" radius="5" fill="RED" />
                        <Label text="53052" styleClass="port-text" />
                    </HBox>
                    <HBox spacing="4" alignment="CENTER">
                        <Circle fx:id="circle53055" radius="5" fill="RED" />
                        <Label text="53055" styleClass="port-text" />
                    </HBox>
                </HBox>
            </HBox>

            <!-- Seletor de Banco -->
            <VBox spacing="6" styleClass="db-selector-box">
                <Label text="📍 Banco de Dados Alvo" styleClass="db-selector-label" />
                <HBox spacing="10">
                    <TextField fx:id="caminhoBancoTextField" editable="false"
                               promptText="Nenhum banco selecionado..."
                               styleClass="db-path-field" HBox.hgrow="ALWAYS" />
                    <Button text="📂 Selecionar FDB" styleClass="action-btn-primary"
                            onAction="#selecionarBancoDeDados" />
                </HBox>
            </VBox>

            <!-- Grade de Ações -->
            <GridPane fx:id="gridAcoes" hgap="12" vgap="12" styleClass="action-grid">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" />
                    <ColumnConstraints percentWidth="50" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                </rowConstraints>

                <Button text="🔧 Verificar Erros" styleClass="action-btn"
                        GridPane.columnIndex="0" GridPane.rowIndex="0"
                        onAction="#gerenciarCliqueVerificar" maxWidth="Infinity" maxHeight="Infinity" />
                <Button text="🛢️ Corrigir Erros" styleClass="action-btn"
                        GridPane.columnIndex="1" GridPane.rowIndex="0"
                        onAction="#gerenciarCliqueCorrigir" maxWidth="Infinity" maxHeight="Infinity" />
                <Button text="♻️ Executar Sweep" styleClass="action-btn"
                        GridPane.columnIndex="0" GridPane.rowIndex="1"
                        onAction="#gerenciarCliqueSweep" maxWidth="Infinity" maxHeight="Infinity" />
                <Button text="📦 Realizar Backup" styleClass="action-btn"
                        GridPane.columnIndex="1" GridPane.rowIndex="1"
                        onAction="#gerenciarCliqueBackup" maxWidth="Infinity" maxHeight="Infinity" />
                <Button text="📥 Restaurar Backup" styleClass="action-btn"
                        GridPane.columnIndex="0" GridPane.rowIndex="2"
                        onAction="#restaurarBackup" maxWidth="Infinity" maxHeight="Infinity" />
                <Button text="⚙ Manutenção Automática" styleClass="action-btn-accent"
                        GridPane.columnIndex="1" GridPane.rowIndex="2"
                        onAction="#gerenciarCliqueManutencaoCompleta" maxWidth="Infinity" maxHeight="Infinity" />
            </GridPane>

            <!-- Progresso & Status -->
            <VBox spacing="5">
                <HBox>
                    <Label text="PROCESSO ATIVO" styleClass="progress-header" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="myStatusLabel" styleClass="progress-status" text="Aguardando..." />
                </HBox>
                <ProgressBar fx:id="myProgressBar" maxWidth="Infinity" progress="0.0" styleClass="progress-bar" />
            </VBox>

            <!-- Terminal de Log -->
            <TextArea fx:id="terminalLogArea" editable="false" styleClass="terminal" VBox.vgrow="ALWAYS" />
        </VBox>
    </center>
</BorderPane>