<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700" prefWidth="1100" stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.nighthawkdb.controller.MssqlController">

    <!-- Barra Lateral -->
    <left>
        <VBox fx:id="sidebarVBox" prefWidth="220" styleClass="sidebar" spacing="8">
            <padding><Insets top="20" right="10" bottom="20" left="10"/></padding>
            <Label text="NighthawksDB" styleClass="sidebar-server-name" />
            <Separator styleClass="sidebar-separator" />
            <Button text="🔥 Firebird/Manutenção" styleClass="nav-button" maxWidth="Infinity" onAction="#navegarParaDashboard"/>
            <Button text="⚖ Comparador Firebird" styleClass="nav-button" maxWidth="Infinity" onAction="#navegarParaCompiler"/>
            <Button text="🔷 MSSQL Tools" styleClass="nav-button, nav-button-active" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="ℹ Sobre" styleClass="nav-button" maxWidth="Infinity" onAction="#abrirJanelaSobre"/>
        </VBox>
    </left>

    <!-- Conteúdo Central Otimizado -->
    <center>
        <VBox spacing="6" styleClass="main-content">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            
            <Label styleClass="main-title" text="MSSQL Tools" />

            <!-- Painel de Conexão Compacto -->
            <VBox spacing="5" styleClass="db-selector-box">
                <HBox spacing="10">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #ccd6e0; -fx-font-size: 11px;" text="Servidor" />
                        <TextField fx:id="txtServer" promptText="localhost" styleClass="db-path-field" />
                    </VBox>
                    <VBox prefWidth="80" spacing="2">
                        <Label style="-fx-text-fill: #ccd6e0; -fx-font-size: 11px;" text="Porta" />
                        <TextField fx:id="txtPort" promptText="1433" styleClass="db-path-field" />
                    </VBox>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #ccd6e0; -fx-font-size: 11px;" text="Banco de Dados" />
                        <TextField fx:id="txtDatabase" promptText="master" styleClass="db-path-field" />
                    </VBox>
                </HBox>
                
                <HBox spacing="10">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #ccd6e0; -fx-font-size: 11px;" text="Usuário (Ex: sa)" />
                        <TextField fx:id="txtUser" promptText="sa" styleClass="db-path-field" />
                    </VBox>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #ccd6e0; -fx-font-size: 11px;" text="Senha" />
                        <PasswordField fx:id="txtPassword" promptText="****" styleClass="db-path-field" />
                    </VBox>
                    <VBox alignment="BOTTOM_CENTER" spacing="5">
                        <HBox spacing="5">
                           <Button text="🔌 Testar Conexão" styleClass="action-btn-primary" onAction="#testaConexao" />
                           <Button text="ℹ Informações" styleClass="action-btn-primary" onAction="#carregarInformacoesBanco" />
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Status rápido -->
            <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 3 0;">
                <Label text="Status:" style="-fx-text-fill: #96a7b6;" />
                <Label fx:id="lblDbStatus" text="Desconhecido" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                <Label text="Tamanho:" style="-fx-text-fill: #96a7b6;" />
                <Label fx:id="lblDbSize" text="---" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                <Label text="Tabelas:" style="-fx-text-fill: #96a7b6;" />
                <Label fx:id="lblTableCount" text="---" style="-fx-text-fill: white; -fx-font-weight: bold;" />
            </HBox>

            <!-- Botões de Ação Menores -->
            <GridPane hgap="8" vgap="8">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.3" />
                    <ColumnConstraints percentWidth="33.3" />
                    <ColumnConstraints percentWidth="33.3" />
                </columnConstraints>
                <rowConstraints><RowConstraints /><RowConstraints /></rowConstraints>

                <Button text="🔍 Verificar Integridade (DBCC)" styleClass="action-btn" GridPane.columnIndex="0" GridPane.rowIndex="0" onAction="#executarCheckDB" maxWidth="Infinity" />
                <Button text="🛠 Rebuild de Índices" styleClass="action-btn" GridPane.columnIndex="1" GridPane.rowIndex="0" onAction="#executarRebuildIndexes" maxWidth="Infinity" />
                <Button text="📊 Atualizar Estatísticas" styleClass="action-btn" GridPane.columnIndex="2" GridPane.rowIndex="0" onAction="#executarUpdateStatistics" maxWidth="Infinity" />
                
                <Button text="💾 Backup da Base (.bak)" styleClass="action-btn" GridPane.columnIndex="0" GridPane.rowIndex="1" onAction="#executarBackup" maxWidth="Infinity" />
                <Button text="📥 Restaurar Backup" styleClass="action-btn" GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#executarRestore" maxWidth="Infinity" />
                
                <HBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="1">
                   <TextField fx:id="txtTableName" promptText="Tabela..." HBox.hgrow="ALWAYS" styleClass="db-path-field" />
                   <Button text="🔬 CHECKTABLE" styleClass="action-btn-accent" onAction="#executarCheckTable" />
                </HBox>
            </GridPane>

            <!-- Terminal -->
            <VBox spacing="2" VBox.vgrow="ALWAYS">
                <HBox>
                    <Label styleClass="progress-header" text="CONSOLE MSSQL" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="myStatusLabel" styleClass="progress-status" text="Pronto." />
                </HBox>
                <ProgressBar fx:id="myProgressBar" maxWidth="Infinity" progress="0.0" styleClass="progress-bar" />
                <TextArea fx:id="terminalLogArea" editable="false" styleClass="terminal" VBox.vgrow="ALWAYS" />
            </VBox>
        </VBox>
    </center>
</BorderPane>